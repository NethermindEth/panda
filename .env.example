# ClickHouse - Xatu cluster (raw event data)
CLICKHOUSE_XATU_HOST=clickhouse.xatu.example.com
CLICKHOUSE_XATU_DATABASE=default
CLICKHOUSE_XATU_USERNAME=your_username
CLICKHOUSE_XATU_PASSWORD=your_password

# ClickHouse - Refined cluster (pre-aggregated data)
CLICKHOUSE_REFINED_HOST=clickhouse-refined.xatu.example.com
CLICKHOUSE_REFINED_DATABASE=default
CLICKHOUSE_REFINED_USERNAME=your_username
CLICKHOUSE_REFINED_PASSWORD=your_password

# ClickHouse - Experimental cluster (devnet data)
CLICKHOUSE_EXPERIMENTAL_HOST=clickhouse-experimental.xatu.example.com
CLICKHOUSE_EXPERIMENTAL_DATABASE=default
CLICKHOUSE_EXPERIMENTAL_USERNAME=your_username
CLICKHOUSE_EXPERIMENTAL_PASSWORD=your_password

# Prometheus/VictoriaMetrics - Platform (Kubernetes metrics)
PROMETHEUS_PLATFORM_URL=https://victoriametrics.platform.example.com
PROMETHEUS_PLATFORM_USERNAME=your_username
PROMETHEUS_PLATFORM_PASSWORD=your_password

# Prometheus - Devnets (bare metal VM metrics)
PROMETHEUS_DEVNETS_URL=https://prometheus.devnets.example.com
PROMETHEUS_DEVNETS_USERNAME=your_username
PROMETHEUS_DEVNETS_PASSWORD=your_password

# Loki - Container logs
LOKI_URL=https://loki.example.com
LOKI_USERNAME=your_username
LOKI_PASSWORD=your_password

# Optional - Server ports
MCP_SERVER_PORT=2480
MCP_METRICS_PORT=2490

# Optional - GitHub OAuth (if auth enabled)
# GITHUB_CLIENT_ID=your_client_id
# GITHUB_CLIENT_SECRET=your_client_secret
