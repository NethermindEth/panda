# Required API keys
OPENROUTER_API_KEY=sk-or-...  # Agent (default: deepseek-v4-flash) + evaluator (default: gemini)
# ANTHROPIC_API_KEY=sk-ant-... # Only if MCP_EVAL_AGENT_API=anthropic with a Claude model

# ethpandaops-panda connection
MCP_EVAL_MCP_URL=http://localhost:2480

# Agent backend / endpoint class:
#   openai    -> OpenAI-compatible chat-completions (e.g. OpenRouter) + native MCP loop
#   anthropic -> Claude Agent SDK (Anthropic Messages API)
MCP_EVAL_AGENT_API=openai

# Model under test. With agent_api=openai, any OpenRouter id (e.g. deepseek/deepseek-v4-flash,
# anthropic/claude-sonnet-4-5). With agent_api=anthropic, any Claude id.
MCP_EVAL_MODEL=deepseek/deepseek-v4-flash

# Reasoning effort for the model under test: none | low | medium | high
MCP_EVAL_REASONING_EFFORT=high

# Optional base URL override for the agent endpoint.
# openai backend defaults to https://openrouter.ai/api/v1; anthropic backend to Anthropic direct.
# MCP_EVAL_AGENT_BASE_URL=
# MCP_EVAL_AGENT_API_KEY_ENV=OPENROUTER_API_KEY  # env var holding the openai-backend key

# Evaluator model (judges the results)
# OpenRouter models (require OPENROUTER_API_KEY):
#   - google/gemini-3-flash-preview (default - fast & cheap)
#   - google/gemini-2.5-pro-preview
#   - anthropic/claude-3.5-sonnet
#   - meta-llama/llama-3.1-70b-instruct
# OpenAI models (require OPENAI_API_KEY):
#   - gpt-4o, gpt-4-turbo
# Anthropic models (require ANTHROPIC_API_KEY):
#   - claude-sonnet-4-5, claude-haiku-4-5
MCP_EVAL_EVALUATOR_MODEL=google/gemini-3-flash-preview

# Evaluation options
MCP_EVAL_VERBOSE=false
MCP_EVAL_TRACK_COSTS=true

# Metric thresholds
MCP_EVAL_TOOL_CORRECTNESS_THRESHOLD=0.5
MCP_EVAL_TASK_COMPLETION_THRESHOLD=0.5
MCP_EVAL_RESOURCE_DISCOVERY_THRESHOLD=0.7

# Optional - Confident AI (for dashboards)
# CONFIDENT_API_KEY=...

# Langfuse (self-hosted trace viewing)
# Start Langfuse: uv run python -m scripts.langfuse up
# View traces at http://localhost:3000 (login: admin@mcp.local / adminadmin)
# Default keys work out of the box - no setup needed!
MCP_EVAL_LANGFUSE_ENABLED=true
# MCP_EVAL_LANGFUSE_HOST=http://localhost:3000
# MCP_EVAL_LANGFUSE_PUBLIC_KEY=pk-lf-mcp-eval-local
# MCP_EVAL_LANGFUSE_SECRET_KEY=sk-lf-mcp-eval-local
